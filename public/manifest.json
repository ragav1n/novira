{
    "name": "Novira",
    "short_name": "Novira",
    "description": "Experience the future of personal finance with Novira. Track spending, manage budgets, and visualize your financial universe.",
    "start_url": "/",
    "display": "standalone",
    "background_color": "#0c081e",
    "theme_color": "#0c081e",
    "orientation": "portrait",
    "categories": ["finance", "lifestyle", "productivity"],
    "icons": [
        {
            "src": "/icons/novira-192.png",
            "sizes": "192x192",
            "type": "image/png",
            "purpose": "any"
        },
        {
            "src": "/icons/novira-512.png",
            "sizes": "512x512",
            "type": "image/png",
            "purpose": "any"
        },
        {
            "src": "/icons/novira-512-maskable.png",
            "sizes": "512x512",
            "type": "image/png",
            "purpose": "maskable"
        }
    ],
    "shortcuts": [
        {
            "name": "Add Expense",
            "short_name": "Add",
            "description": "Quickly add a new expense",
            "url": "/add",
            "icons": [{ "src": "/icons/novira-192.png", "sizes": "192x192" }]
        },
        {
            "name": "Analytics",
            "short_name": "Analytics",
            "description": "View your spending insights",
            "url": "/analytics",
            "icons": [{ "src": "/icons/novira-192.png", "sizes": "192x192" }]
        }
    ],
    "share_target": {
        "action": "/share-target",
        "method": "POST",
        "enctype": "multipart/form-data",
        "params": {
            "files": [
                {
                    "name": "receipt",
                    "accept": ["image/*"]
                }
            ]
        }
    }
}